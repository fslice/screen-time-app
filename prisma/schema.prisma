generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────────────────────────
// Mirrored from Clerk via webhook. Clerk user ID is the primary key.

model User {
  id        String   @id // Clerk user ID (e.g. "user_2abc...")
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices      Device[]
  subscription Subscription?
}

// ── Device ───────────────────────────────────────────────────────────────────
// A device the user has locked with Shutout.
// Stores the encrypted Screen Time passcode and unlock settings.

model Device {
  id                String   @id @default(cuid())
  userId            String
  name              String   // e.g. "iPhone 15", "iPad Pro"
  encryptedPasscode String   // AES-256-GCM ciphertext (hex)
  iv                String   // Initialization vector (hex)
  authTag           String   // GCM auth tag (hex)
  icloudAccount     String   // assigned dummy iCloud email
  wordsRequired     Int      @default(600)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  willpowerSessions WillpowerSession[]
}

// ── WillpowerSession ─────────────────────────────────────────────────────────
// Tracks progress through the word-typing challenge.
// Persisted so a page refresh doesn't reset progress.

model WillpowerSession {
  id                 String    @id @default(cuid())
  deviceId           String
  wordsRequired      Int
  wordsCompleted     Int       @default(0)
  currentWord        String?   // the word the user must type next
  completedAt        DateTime? // set when wordsCompleted >= wordsRequired
  passwordRevealedAt DateTime? // set when password is fetched post-completion
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ── Subscription ─────────────────────────────────────────────────────────────
// Synced from Stripe via webhook. Handles both recurring and lifetime plans.

model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  stripeCustomerId       String    @unique
  stripeSubscriptionId   String?   @unique // null for lifetime (one-time payment)
  stripePriceId          String?
  status                 SubStatus @default(trialing)
  planType               PlanType?
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubStatus {
  trialing
  active
  past_due
  canceled
  lifetime
}

enum PlanType {
  monthly
  annual
  lifetime
}
